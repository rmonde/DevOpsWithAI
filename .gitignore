# Secrets & environment variables
.env
.env.*
*.pem
*.key
*.cert
*.p12
secrets/

# Kubernetes — secrets files contain credentials
k8s/secret.yml
k8s/monitoring/grafana-secret.yml

# Terraform — state files can contain storage keys and resource metadata
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
# terraform.tfvars contains subscription ID — keep out of public repos
# .terraform.lock.hcl is safe to commit (records provider versions), so not listed here
Infrastructure/terraform.tfvars
Infrastructure/bootstrap/terraform.tfvars

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Docker
*.override.yml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code settings — contains Azure subscription ID and local paths
.claude/settings.json
